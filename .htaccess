# StreamSuite — Apache 2.4 configuration
# Requires: mod_rewrite, mod_headers, mod_deflate, mod_expires

Options -Indexes -MultiViews
DirectoryIndex index.php

# ─── URL Rewriting ───────────────────────────────────────────────────────────
RewriteEngine On

# Handle HTTPS behind Cloudflare / reverse proxy
RewriteCond %{HTTP:X-Forwarded-Proto} =http [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Direct HTTPS enforcement (non-proxied)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Pass API requests and real files through unchanged
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d [OR]
RewriteCond %{REQUEST_URI} ^/api/ [NC]
RewriteRule ^ - [L]

# Clean URL routing: /browse → browse.php, /watch → watch.php, etc.
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]
RewriteRule ^([a-z0-9\-]+)/?$ $1.php [L,QSA]

# ─── Block Sensitive Files ────────────────────────────────────────────────────
<FilesMatch "\.(sql|log|sh|env|bak|swp|orig)$">
    Require all denied
</FilesMatch>

<FilesMatch "^(config|db)\.php$">
    Require all denied
</FilesMatch>

# Block dotfiles except .htaccess itself
<FilesMatch "^\.(?!htaccess)">
    Require all denied
</FilesMatch>

# Block CI/dev files from being served
<FilesMatch "\.(yml|yaml|json|md|lock|gitignore|gitattributes)$">
    Require all denied
</FilesMatch>

# ─── Security Headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options    "nosniff"
    Header always set X-Frame-Options           "SAMEORIGIN"
    Header always set Referrer-Policy           "strict-origin-when-cross-origin"
    Header always set Permissions-Policy        "geolocation=(), camera=(), microphone=(), payment=()"
    Header always set X-XSS-Protection          "1; mode=block"

    # Content Security Policy — allows YouTube embeds and TMDB images
    Header always set Content-Security-Policy \
        "default-src 'self'; \
         script-src 'self' 'unsafe-inline'; \
         style-src 'self' 'unsafe-inline' https://fonts.bunny.net https://api.fontshare.com; \
         img-src 'self' data: https://image.tmdb.org https://img.youtube.com; \
         media-src 'none'; \
         frame-src https://vidsrc.cc https://vidlink.pro https://embed.su \
                   https://vidsrc.me https://moviesapi.club https://multiembed.mov \
                   https://www.youtube.com https://www.youtube-nocookie.com; \
         connect-src 'self'; \
         font-src 'self' https://fonts.bunny.net https://api.fontshare.com https://cdn.fontshare.com; \
         object-src 'none'; \
         base-uri 'self'; \
         form-action 'self'"

    # Remove identifying headers
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ─── Compression ─────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml application/xml
    AddOutputFilterByType DEFLATE font/woff2 font/woff font/ttf
</IfModule>

# ─── Browser Caching ─────────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On

    # Fonts — long cache (content-hashed in practice)
    ExpiresByType font/woff2                 "access plus 1 year"
    ExpiresByType font/woff                  "access plus 1 year"

    # Images
    ExpiresByType image/svg+xml              "access plus 1 month"
    ExpiresByType image/webp                 "access plus 1 month"
    ExpiresByType image/png                  "access plus 1 month"
    ExpiresByType image/jpeg                 "access plus 1 month"

    # CSS and JS — 1 week (short enough to catch updates)
    ExpiresByType text/css                   "access plus 1 week"
    ExpiresByType application/javascript     "access plus 1 week"
    ExpiresByType text/javascript            "access plus 1 week"

    # HTML and API responses — no cache
    ExpiresByType text/html                  "access plus 0 seconds"
    ExpiresByType application/json           "access plus 0 seconds"
</IfModule>

# ─── Error Documents ─────────────────────────────────────────────────────────
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
